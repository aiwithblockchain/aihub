[
  {
    "id": "query_ai_status",
    "name": "Query AI Status",
    "method": "GET",
    "path": "/api/v1/ai/status",
    "summary": "查询 AI 平台 Tab 状态",
    "description": "获取当前所有由 aiClaw 扩展捕获的 AI 平台标签页状态，包括 ChatGPT、Gemini、Grok。返回每个标签页的 tabId、URL、是否活动、登录状态等信息。这是机器人感知浏览器中 AI 平台环境的第一步，确保您的 Bot 始终在正确的标签页上执行操作。",
    "curl": "curl -X GET http://127.0.0.1:10088/api/v1/ai/status",
    "response": "{\"tabs\":[{\"platform\":\"chatgpt\",\"tabId\":123456789,\"url\":\"https://chatgpt.com\",\"active\":true,\"isLoggedIn\":true}]}"
  },
  {
    "id": "send_ai_message",
    "name": "Send AI Message",
    "method": "POST",
    "path": "/api/v1/ai/message",
    "summary": "向指定 AI 平台发送消息",
    "description": "向指定的 AI 平台（如 ChatGPT）发送消息并获取 AI 的原始回复。支持在现有对话中继续对话（通过 conversationId）或在当前页面发送新消息。系统会自动通过 DOM 操作将消息输入到 AI 平台的输入框并提交，然后返回 AI 的完整原始响应文本。完全透传 AI 平台的原始回复，不做任何数据处理或格式化。",
    "request_body": "{\n  \"platform\": \"chatgpt\",\n  \"prompt\": \"Hello, how are you?\",\n  \"conversationId\": \"optional-conversation-id\"\n}",
    "curl": "curl -X POST http://127.0.0.1:10088/api/v1/ai/message \\\n     -H \"Content-Type: application/json\" \\\n     -d '{\"platform\":\"chatgpt\", \"prompt\":\"Hello\"}'",
    "response": "{\"success\":true,\"response\":\"Hello! I'm doing well, thank you for asking. How can I help you today?\"}"
  },
  {
    "id": "new_ai_conversation",
    "name": "New AI Conversation",
    "method": "POST",
    "path": "/api/v1/ai/new_conversation",
    "summary": "创建新的 AI 对话",
    "description": "在指定的 AI 平台上创建一个全新的对话。目前主要用于 ChatGPT 平台。该操作会通过 DOM 操作点击\"新对话\"按钮，清空当前上下文，为后续的消息交互提供一个干净的对话环境。适用于需要开始全新话题或避免上下文干扰的场景。",
    "request_body": "{\n  \"platform\": \"chatgpt\"\n}",
    "curl": "curl -X POST http://127.0.0.1:10088/api/v1/ai/new_conversation \\\n     -H \"Content-Type: application/json\" \\\n     -d '{\"platform\":\"chatgpt\"}'",
    "response": "{\"success\":true,\"message\":\"New conversation created\"}"
  },
  {
    "id": "navigate_ai_platform",
    "name": "Navigate AI Platform",
    "method": "POST",
    "path": "/api/v1/ai/navigate",
    "summary": "导航 AI 平台到首页",
    "description": "将指定 AI 平台的所有标签页导航到其首页。这是一个便捷的重置操作，可以让 Bot 快速将浏览器环境恢复到 AI 平台的主界面。支持 ChatGPT、Gemini、Grok 等平台。该操作会自动识别该平台的所有打开标签页并统一导航到首页 URL。",
    "request_body": "{\n  \"platform\": \"chatgpt\"\n}",
    "curl": "curl -X POST http://127.0.0.1:10088/api/v1/ai/navigate \\\n     -H \"Content-Type: application/json\" \\\n     -d '{\"platform\":\"chatgpt\"}'",
    "response": "{\"success\":true,\"message\":\"Navigated to chatgpt home page\"}"
  }
]
